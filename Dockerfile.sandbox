FROM python:3.11-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        default-jdk \
        nodejs \
        npm \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /sandbox && chmod 777 /sandbox
WORKDIR /sandbox

CMD ["sh", "-lc", "echo Sandbox image is ready."]
